using EFCore.TestAggregates.Demo.Entities;
using System;

namespace EFCore.TestAggregates.Demo.Tests.AggregateBuilders;

internal static class TrackBuilder
{
    public static TrackEntity Create(AlbumEntity album, string name, TimeSpan duration)
    {
        return new TrackEntity
        {
            Album = album,
            AlbumId = album.Id,
            Name = name,
            Duration = duration
        };
    }
}
